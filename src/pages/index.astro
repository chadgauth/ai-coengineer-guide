---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TagList from '../components/TagList.astro';
import FileTree from '../components/FileTree.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				padding: 4rem 0 3rem;
				border-bottom: 1px solid var(--border);
				margin-bottom: 3rem;
			}
			.hero h1 {
				font-size: 2.75rem;
				margin-bottom: 1rem;
				letter-spacing: -0.03em;
			}
			.hero h1 .accent {
				color: var(--accent);
			}
			.hero p {
				color: var(--text-secondary);
				font-size: 1.15rem;
				line-height: 1.7;
				max-width: 540px;
				margin: 0;
			}
			.posts-section h2 {
				font-size: 0.85rem;
				font-family: 'Source Sans 3', sans-serif;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: var(--text-secondary);
				margin-bottom: 1.5rem;
				font-weight: 600;
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.post-item {
				margin-bottom: 0;
			}
			.post-link {
				display: block;
				padding: 1.25rem 0;
				border-bottom: 1px solid var(--border);
				text-decoration: none;
				transition: background 0.15s;
			}
			.post-link:hover {
				background: var(--surface);
				margin: 0 -1rem;
				padding: 1.25rem 1rem;
				border-radius: 6px;
				border-color: transparent;
			}
			.post-link:hover + .post-item .post-link,
			.post-item:has(.post-link:hover) + .post-item .post-link {
				border-top-color: transparent;
			}
			.post-title {
				font-family: 'Fraunces', serif;
				font-size: 1.25rem;
				font-weight: 600;
				color: var(--text);
				margin-bottom: 0.35rem;
				line-height: 1.3;
			}
			.post-description {
				color: var(--text-secondary);
				font-size: 0.9rem;
				margin-bottom: 0.5rem;
				line-height: 1.5;
			}
			.post-meta {
				display: flex;
				align-items: center;
				gap: 1rem;
				font-size: 0.8rem;
				color: var(--text-secondary);
			}
			@media (max-width: 640px) {
				.hero h1 {
					font-size: 2.1rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<div class="layout-container">
			<FileTree />
			<main>
				<section class="hero">
					<h1>The AI Co-Engineer <span class="accent">Template Guide</span></h1>
					<p>
						A practical gallery of patterns for making AI agents reliable, context-aware, and aligned with your team's engineering standards. The goal is an AI that operates as an autonomous engineering partner, capable of maintaining high-quality outputs across complex monorepos without constant hand-holding.
					</p>
					
					<div class="hero-actions" style="display: flex; gap: 1rem; margin-top: 2rem;">
						<a href={`${base}blog/the-setup-bot/`} class="sync-button-large">
							SYNC WORKSPACE TO CODEBASE
						</a>
					</div>

					<style>
					.sync-button-large {
						display: inline-flex;
						align-items: center;
						padding: 10px 20px;
						color: var(--text);
						background: transparent;
						border: 1px solid var(--border);
						border-radius: 4px;
						text-decoration: none;
						font-family: 'JetBrains Mono', monospace;
						font-size: 0.9rem;
						font-weight: 500;
						transition: all 0.2s ease;
					}
					.sync-button-large::before {
						content: "⚡️";
						margin-right: 8px;
						font-size: 1.1rem;
						filter: grayscale(100%) contrast(200%);
					}
					.sync-button-large:hover {
						border-color: var(--accent);
						color: var(--accent);
						background: var(--surface-raised);
					}
					</style>

					<div style="margin-top: 1.5rem; color: var(--text-secondary); font-family: 'JetBrains Mono', monospace; font-size: 0.85rem;">
						> Select a file from the explorer on the left to view its implementation protocol.
					</div>
				</section>

				<section class="posts-section">
					<h2>Documentation Overview</h2>
					<ul class="post-list">
						{posts.map((post) => (
							<li class="post-item">
								<a href={`${base}blog/${post.id}/`} class="post-link">
									<div class="post-title">{post.id}.md</div>
									<div class="post-description">{post.data.title} - {post.data.description}</div>
								</a>
							</li>
						))}
					</ul>
				</section>
			</main>
		</div>
		<Footer />
	</body>
</html>
