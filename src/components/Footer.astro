---
const year = new Date().getFullYear();
---

<footer class="status-bar">
	<div class="status-left">
		<a href="https://github.com/chadgauth" target="_blank" class="status-item">
			<svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" style="margin-right: 4px;">
				<path fill-rule="evenodd" d="M7.177 3.073L9.573.677A.25.25 0 0110 .854v4.792a.25.25 0 01-.427.177L7.177 3.427a.25.25 0 010-.354zM3.75 2.5a.75.75 0 100 1.5.75.75 0 000-1.5zm-2.25.75a2.25 2.25 0 113.598 1.802l2.8 2.8a.25.25 0 010 .354l-2.8 2.8A2.25 2.25 0 113.5 12.25a2.25 2.25 0 01-1.5-3.8028A2.8 2.8 0 015.098 7.5L2.3 4.702A2.25 2.25 0 011.5 3.25zM11.5 12.25a.75.75 0 100 1.5.75.75 0 000-1.5zm-2.25.75a2.25 2.25 0 114.5 0 2.25 2.25 0 01-4.5 0z"></path>
			</svg>
			main*
		</a>
		<span class="status-item error-item">
			<svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" style="margin-right: 4px;"><path fill-rule="evenodd" d="M8 1.5a6.5 6.5 0 100 13 6.5 6.5 0 000-13zM0 8a8 8 0 1116 0A8 8 0 010 8zm9 3a1 1 0 11-2 0 1 1 0 012 0zm-.25-6.25a.75.75 0 00-1.5 0v3.5a.75.75 0 001.5 0v-3.5z"></path></svg>
			0
		</span>
		<span class="status-item warning-item">
			<svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" style="margin-right: 4px;"><path fill-rule="evenodd" d="M8.22 1.754a.25.25 0 00-.44 0L1.698 13.132a.25.25 0 00.22.368h12.164a.25.25 0 00.22-.368L8.22 1.754zm-1.763-.707c.659-1.234 2.427-1.234 3.086 0l6.082 11.378A1.75 1.75 0 0114.082 15H1.918a1.75 1.75 0 01-1.543-2.575L6.457 1.047zM9 11a1 1 0 11-2 0 1 1 0 012 0zm-.25-5.25a.75.75 0 00-1.5 0v2.5a.75.75 0 001.5 0v-2.5z"></path></svg>
			0
		</span>
	</div>
	<div class="status-right">
		<span class="status-item">UTF-8</span>
		<span class="status-item">Astro</span>
		<span class="status-item">Prettier</span>
		<span class="status-item">© {year} Chad Gauthier</span>
	</div>
</footer>

<style>
	.status-bar {
		position: fixed;
		bottom: 0;
		left: 0;
		right: 0;
		height: 22px;
		background: #007acc; /* VS Code blue status bar color, or a subtle IDE color */
		color: #ffffff;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0 8px;
		font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
		font-size: 11px;
		z-index: 100;
	}
	
	/* For a darker subtle IDE line instead of blue: */
	.status-bar {
		background: #181818;
		border-top: 1px solid var(--border);
		color: #cccccc;
	}
	
	.status-left, .status-right {
		display: flex;
		height: 100%;
	}
	
	.status-item {
		display: flex;
		align-items: center;
		padding: 0 6px;
		color: inherit;
		text-decoration: none;
		cursor: pointer;
	}
	
	.status-item:hover {
		background: rgba(255, 255, 255, 0.1);
	}
	
	.error-item, .warning-item {
		margin-left: 2px;
	}
</style>
