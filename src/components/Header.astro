---
import { SITE_TITLE } from '../consts';

const pathname = Astro.url.pathname;
const base = import.meta.env.BASE_URL;

// Ensure we don't misclassify the exact /blog or /blog/ root as a post
const isBlogIndex = pathname === `${base}blog` || pathname === `${base}blog/`;
const isPost = pathname.includes('/blog/') && !isBlogIndex;

let activeTabLabel = 'posts.md';

if (isPost) {
	const parts = pathname.split('/').filter(Boolean);
	const slug = parts[parts.length - 1];
	activeTabLabel = `${slug}.md`;
}

const links = [
	{ href: `${base}`, label: 'README.md', icon: 'markdown' },
	{ href: isPost ? pathname : `${base}blog/`, label: activeTabLabel, icon: 'markdown' },
];
---

<header class="editor-header">
	<div class="header-tabs">
		{links.map((link) => {
			const isActive = pathname === link.href || pathname === link.href.slice(0, -1);
			return (
				<a
					href={link.href}
					class:list={['editor-tab', { active: isActive }]}
				>
					<span class={`file-icon ${link.icon}`}></span>
					<span class="tab-label">{link.label}</span>
					{isActive && <span class="tab-close">×</span>}
				</a>
			);
		})}
	</div>
	<div class="header-actions">
		<a href="https://github.com/chadgauth/ai-coengineer-guide" target="_blank" class="action-btn" aria-label="GitHub">
			<svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor">
				<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
			</svg>
		</a>
	</div>
</header>

<style>
	.editor-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		background: var(--surface);
		border-bottom: 1px solid var(--border);
		height: 35px;
		position: sticky;
		top: 0;
		z-index: 10;
		overflow-x: auto;
	}
	
	.header-tabs {
		display: flex;
		height: 100%;
	}
	
	.editor-tab {
		display: flex;
		align-items: center;
		height: 100%;
		padding: 0 12px;
		gap: 6px;
		background: var(--surface);
		color: var(--text-secondary);
		border-right: 1px solid var(--border);
		text-decoration: none;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.8rem;
		cursor: pointer;
		min-width: 120px;
	}
	
	.editor-tab:hover {
		background: var(--surface-raised);
	}
	
	.editor-tab.active {
		background: var(--bg);
		color: var(--accent);
		border-top: 1px solid var(--accent);
		border-bottom: 1px solid transparent;
		margin-bottom: -1px;
	}
	
	.file-icon {
		width: 12px;
		height: 12px;
		border-radius: 2px;
	}
	
	.file-icon.astro {
		background-color: #ff5a03;
	}
	
	.file-icon.markdown {
		background-color: var(--accent-blue);
	}
	
	.tab-label {
		white-space: nowrap;
	}
	
	.tab-close {
		margin-left: auto;
		font-size: 1.2em;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 3px;
		width: 18px;
		height: 18px;
		color: var(--text-secondary);
	}
	
	.tab-close:hover {
		background: rgba(255, 255, 255, 0.1);
		color: var(--text);
	}
	
	.header-actions {
		display: flex;
		align-items: center;
		padding: 0 10px;
	}
	
	.action-btn {
		color: var(--text-secondary);
		display: flex;
		align-items: center;
		justify-content: center;
		width: 24px;
		height: 24px;
		border-radius: 3px;
	}
	
	.action-btn:hover {
		background: rgba(255, 255, 255, 0.1);
		color: var(--text);
	}
	
	/* Hide scrollbar */
	.editor-header::-webkit-scrollbar {
		display: none;
	}
</style>
